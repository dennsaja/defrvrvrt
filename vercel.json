{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/login",          "dest": "/api/login.js" },
    { "src": "/api/register",       "dest": "/api/register.js" },
    { "src": "/api/verify",         "dest": "/api/verify.js" },
    { "src": "/api/resend-verify",  "dest": "/api/resend-verify.js" },
    { "src": "/api/laporan",        "dest": "/api/laporan.js" },
    { "src": "/api/upload",         "dest": "/api/upload.js" },
    { "src": "/api/submit",         "dest": "/api/submit.js" },
    { "src": "/api/admin",          "dest": "/api/admin.js" },
    { "src": "/api/tugas",          "dest": "/api/tugas.js" },
    { "src": "/api/profile",        "dest": "/api/profile.js" },
    { "src": "/(.*)",               "dest": "/index.html" }
  ]
}
